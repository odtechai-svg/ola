# ── Supabase (middleware session refresh — opcional nesta versão) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Google TTS ─────────────────────────────────────────────────────────────────
GOOGLE_TTS_KEY=your-google-tts-api-key

# ── Web Push (VAPID) — gerar com: npx web-push generate-vapid-keys ─────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT=mailto:your@email.com

# ── Cron security (used to authenticate /api/push/daily-reminder) ─────────────
CRON_SECRET=change-me-to-a-random-string
